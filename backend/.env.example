# College Timetable Scheduler — Environment Config
# Copy this file to .env and fill in your actual values

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/college_timetable

# ─── JWT Auth (P12) ────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY_IN_PRODUCTION
JWT_EXPIRE_MINUTES=480    # 8 hours

# ─── Scheduler settings ────────────────────────────────────────────────────────
SOLVER_TIME_LIMIT_SECONDS=60
MAX_WORKERS=4
